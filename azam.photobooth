<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>LUMIÈRE — Premium Photo Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Dancing+Script:wght@400;600;700&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A96E;
    --gold-light: #E8D5B0;
    --gold-dark: #8B6914;
    --silver: #C0C0C0;
    --silver-light: #E8E8E8;
    --obsidian: #0A0A0A;
    --charcoal: #1A1A1A;
    --dark: #111111;
    --mid: #2A2A2A;
    --surface: #1E1E1E;
    --surface2: #252525;
    --glass: rgba(255,255,255,0.04);
    --glass2: rgba(255,255,255,0.08);
    --text-primary: #F5F0E8;
    --text-secondary: #B8B0A0;
    --text-muted: #6B6560;
    --accent: #C9A96E;
    --rose: #D4788A;
    --mint: #7AC5A0;
    --radius: 16px;
    --radius-lg: 24px;
    --radius-xl: 32px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--obsidian);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ══════════════════════════════
     LOADING SCREEN
  ══════════════════════════════ */
  #loader {
    position: fixed; inset: 0; z-index: 9999;
    background: var(--obsidian);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  #loader.hidden { opacity: 0; pointer-events: none; transform: scale(1.05); }

  .loader-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    animation: logoFade 1s ease forwards;
    opacity: 0;
  }
  .loader-sub {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.5em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-top: 0.5rem;
    animation: logoFade 1s 0.3s ease forwards;
    opacity: 0;
  }
  .loader-bar {
    width: 200px; height: 1px;
    background: var(--mid);
    margin-top: 3rem;
    overflow: hidden;
  }
  .loader-fill {
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    animation: loadFill 2s ease forwards;
    width: 0;
  }
  @keyframes logoFade { to { opacity: 1; } }
  @keyframes loadFill { to { width: 100%; } }

  /* ══════════════════════════════
     LANDING PAGE
  ══════════════════════════════ */
  #landing {
    min-height: 100vh;
    display: flex; flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  #landing::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 50%, rgba(201,169,110,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 80% 20%, rgba(212,120,138,0.05) 0%, transparent 50%),
      radial-gradient(ellipse 50% 50% at 60% 80%, rgba(122,197,160,0.04) 0%, transparent 50%);
    pointer-events: none;
  }

  .noise-overlay {
    position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1.5rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(to bottom, rgba(10,10,10,0.9), transparent);
    backdrop-filter: blur(20px);
    border-bottom: 0.5px solid rgba(201,169,110,0.1);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    text-decoration: none;
  }
  .nav-tagline {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .nav-cta {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
    text-decoration: none;
    border: 0.5px solid rgba(201,169,110,0.4);
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    transition: all 0.3s;
    cursor: pointer;
    background: none;
    font-family: 'Inter', sans-serif;
  }
  .nav-cta:hover { background: var(--gold); color: var(--obsidian); }

  /* HERO */
  .hero {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
    position: relative; z-index: 1;
  }
  .hero-eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.5em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: slideUp 0.8s 0.5s ease forwards; opacity: 0;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0.05em;
    color: var(--text-primary);
    animation: slideUp 0.8s 0.7s ease forwards; opacity: 0;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold);
  }
  .hero-desc {
    font-size: clamp(0.8rem, 2vw, 0.95rem);
    color: var(--text-secondary);
    max-width: 450px;
    line-height: 1.8;
    margin: 2rem auto;
    font-weight: 300;
    animation: slideUp 0.8s 0.9s ease forwards; opacity: 0;
  }
  .hero-actions {
    display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
    animation: slideUp 0.8s 1.1s ease forwards; opacity: 0;
    margin-bottom: 4rem;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    color: var(--obsidian);
    border: none;
    padding: 1rem 2.5rem;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
    position: relative; overflow: hidden;
  }
  .btn-primary::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
    opacity: 0; transition: opacity 0.3s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(201,169,110,0.4); }
  .btn-primary:hover::before { opacity: 1; }
  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border: 0.5px solid rgba(255,255,255,0.2);
    padding: 1rem 2rem;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    backdrop-filter: blur(10px);
  }
  .btn-secondary:hover { border-color: var(--gold); color: var(--gold); background: rgba(201,169,110,0.05); }

  /* SCROLL INDICATOR */
  .scroll-hint {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    font-size: 0.55rem; letter-spacing: 0.3em; color: var(--text-muted);
    text-transform: uppercase;
    animation: slideUp 0.8s 1.5s ease forwards, scrollBounce 2s 2.5s ease infinite; opacity: 0;
  }
  .scroll-line {
    width: 0.5px; height: 40px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollLine 2s ease infinite;
  }
  @keyframes scrollBounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(5px); } }
  @keyframes scrollLine { 0% { transform: scaleY(0); transform-origin: top; } 50% { transform: scaleY(1); transform-origin: top; } 51% { transform: scaleY(1); transform-origin: bottom; } 100% { transform: scaleY(0); transform-origin: bottom; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

  /* FEATURES ROW */
  .features-strip {
    display: flex; gap: 0; border-top: 0.5px solid rgba(255,255,255,0.06);
    animation: slideUp 0.8s 1.3s ease forwards; opacity: 0;
  }
  .feature-item {
    flex: 1; padding: 1.5rem; text-align: center;
    border-right: 0.5px solid rgba(255,255,255,0.06);
    transition: background 0.3s;
  }
  .feature-item:last-child { border-right: none; }
  .feature-item:hover { background: var(--glass); }
  .feature-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    color: var(--gold);
    font-weight: 300;
    line-height: 1;
  }
  .feature-label {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-top: 0.25rem;
    display: block;
  }

  /* ══════════════════════════════
     APP SHELL
  ══════════════════════════════ */
  #app {
    display: none;
    min-height: 100vh;
    flex-direction: column;
  }
  #app.active { display: flex; }

  /* APP NAV */
  .app-nav {
    background: var(--charcoal);
    border-bottom: 0.5px solid rgba(201,169,110,0.15);
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    position: sticky; top: 0; z-index: 50;
  }
  .app-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 400;
    letter-spacing: 0.2em; color: var(--gold);
    text-transform: uppercase;
  }
  .app-steps {
    display: flex; gap: 0.25rem;
  }
  .app-step {
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
    border: 0.5px solid rgba(255,255,255,0.1);
    color: var(--text-muted);
    background: transparent;
    font-family: 'Inter', sans-serif;
  }
  .app-step.active { background: var(--gold); color: var(--obsidian); border-color: var(--gold); }
  .app-step.done { border-color: var(--gold); color: var(--gold); }

  /* ══════════════════════════════
     MAIN CONTENT AREA
  ══════════════════════════════ */
  .app-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  /* STEP PANELS */
  .step-panel {
    display: none;
    flex-direction: column;
    flex: 1;
    padding: 1.5rem 1rem;
    gap: 1.25rem;
  }
  .step-panel.active { display: flex; }

  .panel-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--text-primary);
  }
  .panel-sub {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-top: 0.2rem;
  }

  /* LAYOUT SELECTION */
  .layout-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  .layout-card {
    aspect-ratio: 3/4;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    cursor: pointer;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.5rem;
    transition: all 0.3s;
    padding: 1rem;
    position: relative; overflow: hidden;
  }
  .layout-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(201,169,110,0.1), transparent);
    opacity: 0; transition: opacity 0.3s;
  }
  .layout-card:hover { border-color: rgba(201,169,110,0.3); transform: translateY(-2px); }
  .layout-card:hover::before { opacity: 1; }
  .layout-card.selected { border-color: var(--gold); background: rgba(201,169,110,0.08); }
  .layout-card.selected::before { opacity: 1; }
  .layout-preview {
    display: flex; flex-wrap: wrap;
    gap: 2px; justify-content: center;
    width: 60px;
  }
  .layout-thumb {
    background: rgba(201,169,110,0.3);
    border-radius: 3px;
    flex-shrink: 0;
  }
  .layout-name {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--text-secondary);
    text-transform: uppercase;
    text-align: center;
    font-weight: 500;
  }
  .layout-badge {
    position: absolute; top: 8px; right: 8px;
    background: var(--gold);
    color: var(--obsidian);
    font-size: 0.45rem;
    letter-spacing: 0.1em;
    padding: 2px 6px;
    border-radius: 100px;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* TEMPLATE GRID */
  .template-search {
    position: relative;
  }
  .template-search input {
    width: 100%;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 100px;
    padding: 0.7rem 1.2rem 0.7rem 2.8rem;
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    outline: none;
    transition: border-color 0.3s;
  }
  .template-search input:focus { border-color: rgba(201,169,110,0.4); }
  .template-search input::placeholder { color: var(--text-muted); }
  .search-icon {
    position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
    color: var(--text-muted); font-size: 0.8rem;
  }

  .category-tabs {
    display: flex; gap: 0.5rem;
    overflow-x: auto; padding-bottom: 0.25rem;
    scrollbar-width: none;
  }
  .category-tabs::-webkit-scrollbar { display: none; }
  .cat-tab {
    flex-shrink: 0;
    padding: 0.4rem 0.9rem;
    border-radius: 100px;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    color: var(--text-muted);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }
  .cat-tab:hover { color: var(--text-primary); border-color: rgba(255,255,255,0.2); }
  .cat-tab.active { background: var(--gold); color: var(--obsidian); border-color: var(--gold); }

  .template-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  .template-card {
    aspect-ratio: 3/4;
    border-radius: var(--radius);
    cursor: pointer;
    position: relative; overflow: hidden;
    border: 0.5px solid rgba(255,255,255,0.08);
    transition: all 0.3s;
  }
  .template-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.5); }
  .template-card.selected { border-color: var(--gold); box-shadow: 0 0 0 2px var(--gold); }
  .template-bg {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
  }
  .template-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0.75rem 0.5rem 0.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
    font-size: 0.6rem; letter-spacing: 0.1em; color: #fff;
    text-transform: uppercase; font-weight: 500;
  }
  .template-check {
    position: absolute; top: 8px; right: 8px;
    width: 20px; height: 20px;
    background: var(--gold); border-radius: 50%;
    display: none; align-items: center; justify-content: center;
    font-size: 0.6rem; color: var(--obsidian);
  }
  .template-card.selected .template-check { display: flex; }

  /* CAMERA VIEW */
  .camera-container {
    position: relative;
    background: #000;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
    width: 100%;
  }
  #videoEl {
    width: 100%; height: 100%;
    object-fit: cover;
    transform: scaleX(-1);
  }
  .camera-overlay {
    position: absolute; inset: 0;
    pointer-events: none;
  }
  .guide-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(201,169,110,0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,169,110,0.15) 1px, transparent 1px);
    background-size: 33.33% 33.33%;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .guide-grid.visible { opacity: 1; }
  .camera-frame {
    position: absolute; inset: 12px;
    border: 1px solid rgba(201,169,110,0.4);
    border-radius: 4px;
    pointer-events: none;
  }
  .camera-frame::before, .camera-frame::after,
  .camera-frame > span::before, .camera-frame > span::after {
    content: '';
    position: absolute;
    width: 20px; height: 20px;
    border-color: var(--gold);
    border-style: solid;
  }
  .camera-frame::before { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
  .camera-frame::after { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
  .camera-frame > span::before { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
  .camera-frame > span::after { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

  .flash-overlay {
    position: absolute; inset: 0;
    background: #fff;
    opacity: 0; pointer-events: none;
    transition: opacity 0.05s;
  }
  .flash-overlay.flash { opacity: 1; }

  .countdown-display {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 8rem; font-weight: 300;
    color: #fff;
    text-shadow: 0 0 60px rgba(201,169,110,0.8);
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
  }
  .countdown-display.visible { opacity: 1; }

  .pose-guide {
    position: absolute; inset: 0;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
    display: flex; align-items: center; justify-content: center;
  }
  .pose-guide.visible { opacity: 1; }
  .pose-silhouette {
    width: 80px;
    opacity: 0.2;
    filter: brightness(10);
  }

  /* CAMERA CONTROLS */
  .camera-controls {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }
  .ctrl-group {
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .ctrl-label {
    font-size: 0.55rem; letter-spacing: 0.15em;
    color: var(--text-muted); text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .ctrl-btn {
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    padding: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.65rem;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.05em;
  }
  .ctrl-btn:hover { border-color: rgba(201,169,110,0.3); color: var(--text-primary); }
  .ctrl-btn.active { background: rgba(201,169,110,0.1); border-color: var(--gold); color: var(--gold); }

  /* SHUTTER */
  .shutter-area {
    display: flex; align-items: center; justify-content: center; gap: 2rem;
  }
  .shutter-btn {
    width: 70px; height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    border: 4px solid rgba(201,169,110,0.3);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
    position: relative;
  }
  .shutter-btn:hover { transform: scale(1.05); box-shadow: 0 0 40px rgba(201,169,110,0.5); }
  .shutter-btn:active { transform: scale(0.95); }
  .shutter-ring {
    position: absolute; inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(201,169,110,0.3);
    animation: shutterPulse 2s ease infinite;
  }
  @keyframes shutterPulse { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.1); opacity: 0.5; } }
  .shutter-icon { font-size: 1.4rem; }

  .timer-btns {
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .timer-btn {
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    color: var(--text-muted);
    font-size: 0.6rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.1em;
  }
  .timer-btn.active { border-color: var(--gold); color: var(--gold); background: rgba(201,169,110,0.08); }

  /* SHOTS PREVIEW */
  .shots-row {
    display: flex; gap: 0.5rem;
    overflow-x: auto;
    padding: 0.5rem 0;
    scrollbar-width: none;
  }
  .shots-row::-webkit-scrollbar { display: none; }
  .shot-thumb {
    flex-shrink: 0;
    width: 60px; height: 80px;
    background: var(--surface);
    border-radius: 8px;
    border: 0.5px solid rgba(255,255,255,0.1);
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: all 0.2s;
  }
  .shot-thumb img { width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); }
  .shot-thumb .shot-num {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; color: var(--text-muted);
  }
  .shot-thumb:hover { border-color: var(--gold); }
  .shot-thumb.retake-active {
    border-color: var(--rose);
    box-shadow: 0 0 0 2px var(--rose);
  }

  /* ══════════════════════════════
     EDITING PANEL
  ══════════════════════════════ */
  .edit-preview {
    width: 100%;
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }
  #compositeCanvas {
    width: 100%;
    display: block;
  }
  .edit-tools-tabs {
    display: flex; gap: 0;
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .edit-tab {
    flex: 1; padding: 0.6rem 0.25rem;
    background: var(--surface);
    border: none;
    color: var(--text-muted);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    border-right: 0.5px solid rgba(255,255,255,0.06);
    font-family: 'Inter', sans-serif;
  }
  .edit-tab:last-child { border-right: none; }
  .edit-tab.active { background: rgba(201,169,110,0.1); color: var(--gold); }

  .edit-panel-content { display: none; }
  .edit-panel-content.active { display: block; }

  /* SLIDERS */
  .slider-row {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.5rem 0;
  }
  .slider-label {
    font-size: 0.6rem; letter-spacing: 0.1em;
    color: var(--text-muted); text-transform: uppercase;
    min-width: 70px;
  }
  .slider-val {
    font-size: 0.65rem; color: var(--gold);
    min-width: 30px; text-align: right;
    font-weight: 500;
  }
  .custom-range {
    flex: 1;
    -webkit-appearance: none;
    height: 2px;
    background: rgba(255,255,255,0.1);
    border-radius: 100px;
    outline: none;
  }
  .custom-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--gold);
    cursor: pointer;
    border: 2px solid var(--obsidian);
    box-shadow: 0 0 10px rgba(201,169,110,0.4);
    transition: transform 0.2s;
  }
  .custom-range::-webkit-slider-thumb:hover { transform: scale(1.3); }

  /* TONE PRESETS */
  .tone-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem;
  }
  .tone-btn {
    aspect-ratio: 1;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 0.5rem; letter-spacing: 0.1em;
    color: #fff;
    text-align: center;
    display: flex; align-items: flex-end; justify-content: center;
    padding: 0.4rem;
    border: 0.5px solid rgba(255,255,255,0.1);
    transition: all 0.2s;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }
  .tone-btn:hover, .tone-btn.active { border-color: var(--gold); box-shadow: 0 0 0 2px var(--gold); }

  /* STICKER/DECO */
  .deco-scroll {
    display: flex; gap: 0.5rem;
    overflow-x: auto;
    padding: 0.25rem 0;
    scrollbar-width: none;
  }
  .deco-scroll::-webkit-scrollbar { display: none; }
  .deco-item {
    flex-shrink: 0;
    width: 52px; height: 52px;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 1.5rem;
    transition: all 0.2s;
    position: relative;
  }
  .deco-item:hover { border-color: var(--gold); transform: scale(1.1); }
  .deco-item.active { border-color: var(--gold); background: rgba(201,169,110,0.1); }

  /* TEXT TOOLS */
  .text-input-area {
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.1);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    color: var(--text-primary);
    font-size: 0.9rem;
    width: 100%;
    resize: none;
    outline: none;
    font-family: 'Inter', sans-serif;
    transition: border-color 0.3s;
    min-height: 60px;
  }
  .text-input-area:focus { border-color: rgba(201,169,110,0.4); }

  .font-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem;
  }
  .font-btn {
    padding: 0.6rem;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-align: center;
    transition: all 0.2s;
  }
  .font-btn:hover, .font-btn.active { border-color: var(--gold); color: var(--gold); background: rgba(201,169,110,0.08); }

  .color-palette {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
  }
  .color-swatch {
    width: 28px; height: 28px;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.2s;
    border: 2px solid transparent;
  }
  .color-swatch:hover { transform: scale(1.15); }
  .color-swatch.selected { border-color: #fff; transform: scale(1.15); }

  /* ══════════════════════════════
     OUTPUT / EXPORT
  ══════════════════════════════ */
  .export-preview {
    border-radius: var(--radius);
    overflow: hidden;
    border: 0.5px solid rgba(201,169,110,0.3);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  #exportCanvas {
    width: 100%;
    display: block;
  }

  .export-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;
  }
  .export-btn {
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    padding: 1rem;
    cursor: pointer;
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    transition: all 0.3s;
    color: var(--text-secondary);
    font-family: 'Inter', sans-serif;
  }
  .export-btn:hover { border-color: rgba(201,169,110,0.3); color: var(--text-primary); background: var(--glass); }
  .export-icon { font-size: 1.5rem; }
  .export-label {
    font-size: 0.6rem; letter-spacing: 0.15em;
    text-transform: uppercase; font-weight: 500;
  }
  .export-desc {
    font-size: 0.55rem;
    color: var(--text-muted);
    text-align: center;
  }

  .export-btn-primary {
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    border: none;
    border-radius: var(--radius);
    padding: 1.1rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    color: var(--obsidian);
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: all 0.3s;
    width: 100%;
  }
  .export-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(201,169,110,0.4); }

  /* BOTTOM NAV */
  .app-bottom-nav {
    background: var(--charcoal);
    border-top: 0.5px solid rgba(255,255,255,0.08);
    padding: 0.75rem 1rem;
    display: flex; gap: 0.75rem;
    position: sticky; bottom: 0;
  }
  .nav-btn-back {
    flex: 0;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    padding: 0.75rem 1.25rem;
    color: var(--text-secondary);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }
  .nav-btn-back:hover { color: var(--text-primary); }
  .nav-btn-next {
    flex: 1;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    border: none;
    border-radius: var(--radius);
    padding: 0.75rem;
    color: var(--obsidian);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    font-family: 'Inter', sans-serif;
  }
  .nav-btn-next:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(201,169,110,0.4); }
  .nav-btn-next:disabled { opacity: 0.4; transform: none; box-shadow: none; cursor: not-allowed; }

  /* SECTION HEADER */
  .section-hd {
    display: flex; align-items: center; justify-content: space-between;
  }
  .section-hd-title {
    font-size: 0.65rem; letter-spacing: 0.2em;
    color: var(--text-muted); text-transform: uppercase;
  }
  .section-hd-action {
    font-size: 0.6rem; color: var(--gold);
    cursor: pointer; letter-spacing: 0.1em;
    border: none; background: none; font-family: 'Inter', sans-serif;
  }

  /* TOAST */
  .toast {
    position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: var(--charcoal);
    border: 0.5px solid rgba(201,169,110,0.3);
    border-radius: 100px;
    padding: 0.6rem 1.5rem;
    font-size: 0.7rem;
    color: var(--text-primary);
    letter-spacing: 0.05em;
    z-index: 200;
    opacity: 0;
    transition: all 0.3s;
    pointer-events: none;
    white-space: nowrap;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(201,169,110,0.2); border-radius: 100px; }

  /* GLASS CARD */
  .glass-card {
    background: rgba(255,255,255,0.03);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    backdrop-filter: blur(10px);
    padding: 1rem;
  }

  /* DIVIDER */
  .divider {
    height: 0.5px;
    background: rgba(255,255,255,0.06);
    margin: 0.25rem 0;
  }

  /* FILTER CANVAS */
  .filter-canvas-hidden {
    display: none;
  }

  /* PHOTO STRIP PREVIEW */
  .strip-slot {
    position: relative;
    background: rgba(0,0,0,0.3);
    border-radius: 4px;
    overflow: hidden;
    border: 0.5px dashed rgba(201,169,110,0.3);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-muted);
    font-size: 0.6rem;
  }
  .strip-slot img { width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); }
  .strip-slot.filled { border-style: solid; border-color: rgba(201,169,110,0.2); }

  /* SUCCESS STATE */
  .success-icon {
    width: 60px; height: 60px;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem;
    margin: 0 auto 1rem;
    animation: successPop 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  @keyframes successPop {
    0% { transform: scale(0); opacity: 0; }
    70% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
  }

  /* WATERMARK INPUT */
  .wm-row {
    display: flex; gap: 0.5rem; align-items: center;
  }
  .wm-input {
    flex: 1;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    color: var(--text-primary);
    font-size: 0.75rem;
    font-family: 'Inter', sans-serif;
    outline: none;
  }
  .wm-input:focus { border-color: rgba(201,169,110,0.4); }
  .wm-toggle {
    width: 40px; height: 22px;
    background: rgba(255,255,255,0.1);
    border-radius: 100px;
    cursor: pointer;
    position: relative;
    transition: background 0.3s;
    border: none;
  }
  .wm-toggle::after {
    content: '';
    position: absolute;
    width: 16px; height: 16px;
    background: #fff;
    border-radius: 50%;
    top: 3px; left: 3px;
    transition: transform 0.3s;
  }
  .wm-toggle.on { background: var(--gold); }
  .wm-toggle.on::after { transform: translateX(18px); }

</style>
</head>
<body>

<div class="noise-overlay"></div>

<!-- LOADING -->
<div id="loader">
  <div class="loader-logo">Azam</div>
  <div class="loader-sub">Premium Photo Studio</div>
  <div class="loader-bar"><div class="loader-fill"></div></div>
</div>

<!-- ══════ LANDING PAGE ══════ -->
<section id="landing">
  <nav>
    <a class="nav-logo" href="#">Azam</a>
    <div class="nav-tagline">Studio Foto Premium</div>
    <button class="nav-cta" onclick="startApp()">Mulai →</button>
  </nav>

  <div class="hero">
    <div class="hero-eyebrow">✦ Photo Booth Experience</div>
    <h1 class="hero-title">
      Abadikan<br><em>Momen</em><br>Indah
    </h1>
    <p class="hero-desc">Studio foto premium dalam genggaman. Ratusan template elegan, filter sinematik, dan pengalaman yang tak terlupakan.</p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="startApp()">Buka Studio →</button>
      <button class="btn-secondary">Lihat Galeri</button>
    </div>

    <div class="features-strip">
      <div class="feature-item">
        <div class="feature-num">100+</div>
        <span class="feature-label">Template</span>
      </div>
      <div class="feature-item">
        <div class="feature-num">12</div>
        <span class="feature-label">Kategori</span>
      </div>
      <div class="feature-item">
        <div class="feature-num">4K</div>
        <span class="feature-label">Export</span>
      </div>
    </div>
  </div>

  <div class="scroll-hint">
    <div class="scroll-line"></div>
    Scroll
  </div>
</section>

<!-- ══════ APP SHELL ══════ -->
<div id="app">
  <header class="app-nav">
    <span class="app-logo">Azam</span>
    <div class="app-steps">
      <button class="app-step active" id="step-dot-1" onclick="goToStep(1)">1</button>
      <button class="app-step" id="step-dot-2" onclick="goToStep(2)">2</button>
      <button class="app-step" id="step-dot-3" onclick="goToStep(3)">3</button>
      <button class="app-step" id="step-dot-4" onclick="goToStep(4)">4</button>
      <button class="app-step" id="step-dot-5" onclick="goToStep(5)">5</button>
    </div>
  </header>

  <div class="app-content">

    <!-- ══ STEP 1: LAYOUT ══ -->
    <div class="step-panel active" id="step-1">
      <div>
        <div class="panel-title">Pilih Layout</div>
        <div class="panel-sub">Tentukan komposisi foto Anda</div>
      </div>

      <div class="layout-grid">
        <div class="layout-card" onclick="selectLayout('single')" id="layout-single">
          <div class="layout-badge">Portrait</div>
          <div class="layout-preview">
            <div class="layout-thumb" style="width:50px;height:70px;"></div>
          </div>
          <div class="layout-name">1 Foto</div>
        </div>
        <div class="layout-card" onclick="selectLayout('quad')" id="layout-quad">
          <div class="layout-preview" style="width:54px;flex-wrap:wrap;gap:3px;">
            <div class="layout-thumb" style="width:25px;height:33px;"></div>
            <div class="layout-thumb" style="width:25px;height:33px;"></div>
            <div class="layout-thumb" style="width:25px;height:33px;"></div>
            <div class="layout-thumb" style="width:25px;height:33px;"></div>
          </div>
          <div class="layout-name">4 Foto Grid</div>
        </div>
        <div class="layout-card" onclick="selectLayout('strip')" id="layout-strip">
          <div class="layout-badge">Aesthetic</div>
          <div class="layout-preview" style="flex-direction:column;gap:3px;width:30px;">
            <div class="layout-thumb" style="width:30px;height:18px;"></div>
            <div class="layout-thumb" style="width:30px;height:18px;"></div>
            <div class="layout-thumb" style="width:30px;height:18px;"></div>
            <div class="layout-thumb" style="width:30px;height:18px;"></div>
            <div class="layout-thumb" style="width:30px;height:18px;"></div>
            <div class="layout-thumb" style="width:30px;height:18px;"></div>
          </div>
          <div class="layout-name">6 Strip</div>
        </div>
      </div>

      <div class="glass-card">
        <div style="font-size:0.65rem;color:var(--text-muted);letter-spacing:0.1em;margin-bottom:0.5rem;text-transform:uppercase;">Preview Komposisi</div>
        <div id="layout-preview-box" style="background:var(--obsidian);border-radius:8px;padding:1rem;display:flex;align-items:center;justify-content:center;min-height:80px;">
          <div style="font-size:0.7rem;color:var(--text-muted);">Pilih layout di atas</div>
        </div>
      </div>
    </div>

    <!-- ══ STEP 2: TEMPLATE ══ -->
    <div class="step-panel" id="step-2">
      <div>
        <div class="panel-title">Pilih Template</div>
        <div class="panel-sub">100+ desain premium tersedia</div>
      </div>

      <div class="template-search">
        <span class="search-icon">⌕</span>
        <input type="text" placeholder="Cari template..." oninput="filterTemplates(this.value)">
      </div>

      <div class="category-tabs" id="cat-tabs">
        <button class="cat-tab active" onclick="setCategory('all', this)">Semua</button>
        <button class="cat-tab" onclick="setCategory('luxury', this)">Luxury</button>
        <button class="cat-tab" onclick="setCategory('cute', this)">Cute</button>
        <button class="cat-tab" onclick="setCategory('korean', this)">Korean</button>
        <button class="cat-tab" onclick="setCategory('vintage', this)">Vintage</button>
        <button class="cat-tab" onclick="setCategory('minimal', this)">Minimal</button>
        <button class="cat-tab" onclick="setCategory('dark', this)">Dark</button>
        <button class="cat-tab" onclick="setCategory('colorful', this)">Colorful</button>
        <button class="cat-tab" onclick="setCategory('birthday', this)">Birthday</button>
        <button class="cat-tab" onclick="setCategory('wedding', this)">Wedding</button>
        <button class="cat-tab" onclick="setCategory('graduation', this)">Grad</button>
        <button class="cat-tab" onclick="setCategory('cinematic', this)">Cinematic</button>
      </div>

      <div class="template-grid" id="template-grid">
        <!-- Populated by JS -->
      </div>
    </div>

    <!-- ══ STEP 3: CAMERA ══ -->
    <div class="step-panel" id="step-3">
      <div>
        <div class="panel-title">Studio Foto</div>
        <div class="panel-sub">Ambil foto Anda</div>
      </div>

      <!-- SHOTS TRACKER -->
      <div class="section-hd">
        <div class="section-hd-title">Foto diambil: <span id="shots-count">0</span>/<span id="shots-needed">1</span></div>
        <button class="section-hd-action" onclick="clearShots()">Reset</button>
      </div>

      <div class="shots-row" id="shots-row">
        <!-- Populated by JS -->
      </div>

      <!-- CAMERA -->
      <div class="camera-container">
        <video id="videoEl" autoplay muted playsinline></video>
        <div class="camera-overlay">
          <div class="camera-frame"><span></span></div>
          <div class="guide-grid" id="guide-grid"></div>
          <div class="pose-guide" id="pose-guide">
            <div style="font-size:4rem;opacity:0.3;filter:blur(1px);">🧍</div>
          </div>
        </div>
        <div class="flash-overlay" id="flash-overlay"></div>
        <div class="countdown-display" id="countdown">3</div>
        <canvas id="snapCanvas" style="display:none;"></canvas>
      </div>

      <!-- CAMERA CONTROLS -->
      <div class="camera-controls">
        <div class="ctrl-group">
          <div class="ctrl-label">Countdown</div>
          <div class="timer-btns">
            <button class="timer-btn active" onclick="setTimer(0, this)">Langsung</button>
            <button class="timer-btn" onclick="setTimer(3, this)">3 Detik</button>
            <button class="timer-btn" onclick="setTimer(5, this)">5 Detik</button>
            <button class="timer-btn" onclick="setTimer(10, this)">10 Detik</button>
          </div>
        </div>

        <div style="display:flex;align-items:center;justify-content:center;">
          <div class="shutter-area">
            <div>
              <div class="shutter-btn" onclick="capturePhoto()" id="shutter-btn">
                <div class="shutter-ring"></div>
                <span class="shutter-icon">📷</span>
              </div>
            </div>
          </div>
        </div>

        <div class="ctrl-group">
          <div class="ctrl-label">Efek</div>
          <button class="ctrl-btn" id="btn-guide" onclick="toggleGuide()">Grid Guide</button>
          <button class="ctrl-btn" id="btn-pose" onclick="togglePose()">Pose Guide</button>
          <button class="ctrl-btn" id="btn-mirror" onclick="toggleMirror()">Mirror</button>
        </div>
      </div>

      <!-- FILTER PRESETS -->
      <div>
        <div class="ctrl-label" style="margin-bottom:0.5rem;">Filter Kamera</div>
        <div class="deco-scroll" id="camera-filters">
          <div class="deco-item active" onclick="setCameraFilter('none', this)" title="Normal" style="font-size:0.55rem;letter-spacing:0.05em;color:var(--text-secondary);">Normal</div>
          <div class="deco-item" onclick="setCameraFilter('beauty', this)" title="Beauty" style="font-size:0.55rem;">✨</div>
          <div class="deco-item" onclick="setCameraFilter('warm', this)" title="Warm" style="font-size:0.55rem;">🌅</div>
          <div class="deco-item" onclick="setCameraFilter('cool', this)" title="Cool" style="font-size:0.55rem;">❄️</div>
          <div class="deco-item" onclick="setCameraFilter('bw', this)" title="B&W" style="font-size:0.55rem;color:var(--text-secondary);">B&W</div>
          <div class="deco-item" onclick="setCameraFilter('vintage', this)" title="Vintage" style="font-size:0.55rem;">🎞️</div>
        </div>
      </div>
    </div>

    <!-- ══ STEP 4: EDIT ══ -->
    <div class="step-panel" id="step-4">
      <div>
        <div class="panel-title">Edit & Dekorasi</div>
        <div class="panel-sub">Personalisasi foto Anda</div>
      </div>

      <div class="edit-preview">
        <canvas id="compositeCanvas"></canvas>
      </div>

      <div class="edit-tools-tabs">
        <button class="edit-tab active" onclick="setEditTab('adjust', this)">Adjust</button>
        <button class="edit-tab" onclick="setEditTab('filter', this)">Filter</button>
        <button class="edit-tab" onclick="setEditTab('deco', this)">Deko</button>
        <button class="edit-tab" onclick="setEditTab('text', this)">Teks</button>
        <button class="edit-tab" onclick="setEditTab('frame', this)">Frame</button>
      </div>

      <!-- ADJUST -->
      <div class="edit-panel-content active" id="edit-adjust">
        <div class="slider-row">
          <div class="slider-label">Brightness</div>
          <input type="range" class="custom-range" min="-100" max="100" value="0" oninput="adjustImage('brightness', this.value); this.nextElementSibling.textContent = this.value">
          <div class="slider-val">0</div>
        </div>
        <div class="slider-row">
          <div class="slider-label">Contrast</div>
          <input type="range" class="custom-range" min="-100" max="100" value="0" oninput="adjustImage('contrast', this.value); this.nextElementSibling.textContent = this.value">
          <div class="slider-val">0</div>
        </div>
        <div class="slider-row">
          <div class="slider-label">Saturation</div>
          <input type="range" class="custom-range" min="-100" max="100" value="0" oninput="adjustImage('saturation', this.value); this.nextElementSibling.textContent = this.value">
          <div class="slider-val">0</div>
        </div>
        <div class="slider-row">
          <div class="slider-label">Sharpness</div>
          <input type="range" class="custom-range" min="0" max="100" value="0" oninput="adjustImage('sharpness', this.value); this.nextElementSibling.textContent = this.value">
          <div class="slider-val">0</div>
        </div>
        <div class="slider-row">
          <div class="slider-label">Vignette</div>
          <input type="range" class="custom-range" min="0" max="100" value="0" oninput="adjustImage('vignette', this.value); this.nextElementSibling.textContent = this.value">
          <div class="slider-val">0</div>
        </div>
      </div>

      <!-- FILTER -->
      <div class="edit-panel-content" id="edit-filter">
        <div class="tone-grid">
          <div class="tone-btn active" style="background:linear-gradient(135deg,#888,#444);" onclick="applyTone('none',this)">Original</div>
          <div class="tone-btn" style="background:linear-gradient(135deg,#c8a97e,#8b6914);" onclick="applyTone('warm',this)">Warm</div>
          <div class="tone-btn" style="background:linear-gradient(135deg,#7db8d4,#2d5a7a);" onclick="applyTone('cool',this)">Cool</div>
          <div class="tone-btn" style="background:linear-gradient(135deg,#666,#111);" onclick="applyTone('bw',this)">B&W</div>
          <div class="tone-btn" style="background:linear-gradient(135deg,#d4a070,#604020);" onclick="applyTone('vintage',this)">Vintage</div>
          <div class="tone-btn" style="background:linear-gradient(135deg,#1a1a2e,#0a0a14);" onclick="applyTone('cinematic',this)">Cinematic</div>
          <div class="tone-btn" style="background:linear-gradient(135deg,#d4b8c0,#8a5060);" onclick="applyTone('rose',this)">Rose</div>
          <div class="tone-btn" style="background:linear-gradient(135deg,#b8d4c0,#406050);" onclick="applyTone('mint',this)">Mint</div>
        </div>
      </div>

      <!-- DEKO -->
      <div class="edit-panel-content" id="edit-deco">
        <div class="ctrl-label" style="margin-bottom:0.5rem;">Stiker & Elemen</div>
        <div class="deco-scroll" id="sticker-row">
          <div class="deco-item" onclick="addSticker('🌸')">🌸</div>
          <div class="deco-item" onclick="addSticker('⭐')">⭐</div>
          <div class="deco-item" onclick="addSticker('💫')">💫</div>
          <div class="deco-item" onclick="addSticker('✨')">✨</div>
          <div class="deco-item" onclick="addSticker('💖')">💖</div>
          <div class="deco-item" onclick="addSticker('🌙')">🌙</div>
          <div class="deco-item" onclick="addSticker('🦋')">🦋</div>
          <div class="deco-item" onclick="addSticker('🌹')">🌹</div>
          <div class="deco-item" onclick="addSticker('🎀')">🎀</div>
          <div class="deco-item" onclick="addSticker('👑')">👑</div>
          <div class="deco-item" onclick="addSticker('💎')">💎</div>
          <div class="deco-item" onclick="addSticker('🌟')">🌟</div>
          <div class="deco-item" onclick="addSticker('🎵')">🎵</div>
          <div class="deco-item" onclick="addSticker('🦄')">🦄</div>
          <div class="deco-item" onclick="addSticker('🍒')">🍒</div>
          <div class="deco-item" onclick="addSticker('🎊')">🎊</div>
        </div>

        <div class="divider" style="margin:0.75rem 0;"></div>
        <div class="ctrl-label" style="margin-bottom:0.5rem;">Border Frame</div>
        <div class="deco-scroll">
          <div class="deco-item" onclick="addBorder('gold')" style="font-size:0.5rem;color:var(--gold);border-color:var(--gold);">Gold</div>
          <div class="deco-item" onclick="addBorder('silver')" style="font-size:0.5rem;color:#C0C0C0;border-color:#C0C0C0;">Silver</div>
          <div class="deco-item" onclick="addBorder('neon')" style="font-size:0.5rem;color:#0ff;border-color:#0ff;">Neon</div>
          <div class="deco-item" onclick="addBorder('rose')" style="font-size:0.5rem;color:#D4788A;border-color:#D4788A;">Rose</div>
          <div class="deco-item" onclick="addBorder('none')" style="font-size:0.5rem;">None</div>
        </div>

        <div class="divider" style="margin:0.75rem 0;"></div>
        <div class="ctrl-label" style="margin-bottom:0.5rem;">Watermark & Caption</div>
        <div class="wm-row">
          <input class="wm-input" type="text" id="watermark-text" placeholder="Watermark / Caption..." value="LUMIÈRE Studio">
          <button class="wm-toggle on" id="wm-toggle" onclick="toggleWatermark(this)"></button>
        </div>
        <div style="margin-top:0.5rem;display:flex;align-items:center;gap:0.5rem;">
          <label style="font-size:0.6rem;color:var(--text-muted);">Tanggal Otomatis:</label>
          <button class="wm-toggle on" id="date-toggle" onclick="toggleDate(this)"></button>
        </div>
      </div>

      <!-- TEXT -->
      <div class="edit-panel-content" id="edit-text">
        <textarea class="text-input-area" id="custom-text" placeholder="Tulis teks di sini...&#10;e.g. Best Friends Forever 💕"></textarea>

        <div class="ctrl-label" style="margin:0.5rem 0 0.4rem;">Pilih Font</div>
        <div class="font-grid">
          <div class="font-btn active" style="font-family:'Cormorant Garamond',serif;" onclick="setFont('cormorant', this)">Cormorant</div>
          <div class="font-btn" style="font-family:'Dancing Script',cursive;" onclick="setFont('dancing', this)">Dancing</div>
          <div class="font-btn" style="font-family:'Playfair Display',serif;" onclick="setFont('playfair', this)">Playfair</div>
          <div class="font-btn" style="font-family:'Space Grotesk',sans-serif;" onclick="setFont('grotesk', this)">Grotesk</div>
        </div>

        <div class="ctrl-label" style="margin:0.5rem 0 0.4rem;">Warna Teks</div>
        <div class="color-palette">
          <div class="color-swatch selected" style="background:#FFFFFF;" onclick="setTextColor('#FFFFFF', this)"></div>
          <div class="color-swatch" style="background:#C9A96E;" onclick="setTextColor('#C9A96E', this)"></div>
          <div class="color-swatch" style="background:#D4788A;" onclick="setTextColor('#D4788A', this)"></div>
          <div class="color-swatch" style="background:#7AC5A0;" onclick="setTextColor('#7AC5A0', this)"></div>
          <div class="color-swatch" style="background:#0A0A0A;" onclick="setTextColor('#0A0A0A', this)"></div>
          <div class="color-swatch" style="background:#C0C0C0;" onclick="setTextColor('#C0C0C0', this)"></div>
          <div class="color-swatch" style="background:#FF6B9D;" onclick="setTextColor('#FF6B9D', this)"></div>
          <div class="color-swatch" style="background:#00FFFF;" onclick="setTextColor('#00FFFF', this)"></div>
        </div>

        <div class="slider-row" style="margin-top:0.5rem;">
          <div class="slider-label">Ukuran</div>
          <input type="range" class="custom-range" min="12" max="80" value="28" oninput="setTextSize(this.value); this.nextElementSibling.textContent = this.value + 'px'">
          <div class="slider-val">28px</div>
        </div>

        <button onclick="addTextOverlay()" style="margin-top:0.5rem;background:var(--surface);border:0.5px solid rgba(201,169,110,0.3);border-radius:var(--radius);padding:0.65rem;color:var(--gold);font-size:0.7rem;font-family:'Inter',sans-serif;cursor:pointer;width:100%;letter-spacing:0.1em;text-transform:uppercase;">
          + Tambah Teks ke Foto
        </button>
      </div>

      <!-- FRAME -->
      <div class="edit-panel-content" id="edit-frame">
        <div class="ctrl-label" style="margin-bottom:0.5rem;">Dekorasi Pinggiran</div>
        <div class="deco-scroll">
          <div class="deco-item" onclick="addFrameDeco('flowers')" style="font-size:0.55rem;color:var(--text-secondary);">🌺 Bunga</div>
          <div class="deco-item" onclick="addFrameDeco('stars')" style="font-size:0.55rem;color:var(--gold);">✨ Glitter</div>
          <div class="deco-item" onclick="addFrameDeco('hearts')" style="font-size:0.55rem;color:var(--rose);">💕 Hearts</div>
          <div class="deco-item" onclick="addFrameDeco('ribbons')" style="font-size:0.55rem;color:var(--text-secondary);">🎀 Ribbon</div>
          <div class="deco-item" onclick="addFrameDeco('doodle')" style="font-size:0.55rem;color:var(--text-secondary);">✏️ Doodle</div>
          <div class="deco-item" onclick="addFrameDeco('none')" style="font-size:0.5rem;">None</div>
        </div>

        <div class="divider" style="margin:0.75rem 0;"></div>

        <div class="ctrl-label" style="margin-bottom:0.5rem;">Teks Aesthetic Pinggiran</div>
        <div class="deco-scroll">
          <div class="deco-item" onclick="addEdgeText('forever')" style="font-size:0.5rem;font-family:'Dancing Script',cursive;color:var(--gold);">Forever</div>
          <div class="deco-item" onclick="addEdgeText('love')" style="font-size:0.5rem;font-family:'Dancing Script',cursive;color:var(--rose);">Love</div>
          <div class="deco-item" onclick="addEdgeText('memories')" style="font-size:0.5rem;font-family:'Dancing Script',cursive;color:var(--text-secondary);">Memories</div>
          <div class="deco-item" onclick="addEdgeText('friends')" style="font-size:0.5rem;font-family:'Dancing Script',cursive;color:var(--mint);">Friends</div>
          <div class="deco-item" onclick="addEdgeText('custom')" style="font-size:0.5rem;color:var(--text-muted);">Custom</div>
        </div>
      </div>

      <button class="nav-btn-next" onclick="renderComposite()">Render Preview ↑</button>
    </div>

    <!-- ══ STEP 5: EXPORT ══ -->
    <div class="step-panel" id="step-5">
      <div style="text-align:center;">
        <div class="success-icon">✦</div>
        <div class="panel-title" style="text-align:center;">Foto Siap!</div>
        <div class="panel-sub" style="text-align:center;margin-top:0.25rem;">Download atau bagikan karya Anda</div>
      </div>

      <div class="export-preview">
        <canvas id="exportCanvas"></canvas>
      </div>

      <button class="export-btn-primary" onclick="downloadHD()">
        <span>⬇</span> Download HD
      </button>

      <div class="export-grid">
        <button class="export-btn" onclick="shareInstagram()">
          <span class="export-icon">📸</span>
          <span class="export-label">Instagram</span>
          <span class="export-desc">Story & Feed</span>
        </button>
        <button class="export-btn" onclick="shareWhatsApp()">
          <span class="export-icon">💬</span>
          <span class="export-label">WhatsApp</span>
          <span class="export-desc">Kirim langsung</span>
        </button>
        <button class="export-btn" onclick="generateQR()">
          <span class="export-icon">⬛</span>
          <span class="export-label">QR Code</span>
          <span class="export-desc">Scan & download</span>
        </button>
        <button class="export-btn" onclick="printMode()">
          <span class="export-icon">🖨</span>
          <span class="export-label">Print</span>
          <span class="export-desc">Cetak langsung</span>
        </button>
      </div>

      <button onclick="startNew()" style="background:transparent;border:0.5px solid rgba(255,255,255,0.1);border-radius:var(--radius);padding:0.75rem;color:var(--text-muted);font-size:0.65rem;font-family:'Inter',sans-serif;cursor:pointer;width:100%;letter-spacing:0.15em;text-transform:uppercase;transition:all 0.2s;" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">
        ↺ Buat Foto Baru
      </button>
    </div>

  </div><!-- end app-content -->

  <div class="app-bottom-nav" id="app-bottom-nav">
    <button class="nav-btn-back" id="btn-back" onclick="prevStep()" style="display:none;">← Kembali</button>
    <button class="nav-btn-next" id="btn-next" onclick="nextStep()">Pilih Template →</button>
  </div>
</div><!-- end app -->

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- HIDDEN CANVASES -->
<canvas id="filterCanvas" class="filter-canvas-hidden"></canvas>

<script>
// ══════════════════════════════
// STATE
// ══════════════════════════════
const state = {
