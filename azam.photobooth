// Filter extra minimal templates
const extraTemplates = Array.from({length: 12}, (_, i) => ({
  id: `extra${i+1}`,
  name: `Design ${93+i}`,
  cat: ['luxury','cute','korean','vintage','minimal','dark','colorful','birthday','wedding','graduation','cinematic','minimal'][i % 12],
  bg: `hsl(${i*30},40%,${i%2?15:85}%)`,
  border: i%2 ? '#C9A96E' : '#888',
  accent: '#C9A96E'
}));
const allTemplates = [...templates, ...extraTemplates];

let filteredTemplates = [...allTemplates];
let activeCategory = 'all';

// ══════════════════════════════
// LOADER
// ══════════════════════════════
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('loader').classList.add('hidden');
  }, 2500);
});

// ══════════════════════════════
// APP INIT
// ══════════════════════════════
function startApp() {
  document.getElementById('landing').style.display = 'none';
  document.getElementById('app').classList.add('active');
  renderTemplates();
  initCamera();
  updateStepUI();
}

function startNew() {
  state.shots = [];
  state.stickers = [];
  state.texts = [];
  state.tone = 'none';
  state.adjustments = { brightness: 0, contrast: 0, saturation: 0, sharpness: 0, vignette: 0 };
  goToStep(1);
}

// ══════════════════════════════
// STEP NAVIGATION
// ══════════════════════════════
function goToStep(n) {
  if (n < 1 || n > 5) return;
  if (n === 3 && !state.layout) { showToast('Pilih layout dulu'); return; }
  if (n === 4 && state.shots.length < SHOTS_NEEDED[state.layout]) { showToast('Ambil semua foto dulu'); return; }
  if (n === 5 && state.shots.length < SHOTS_NEEDED[state.layout]) { showToast('Selesaikan foto dulu'); return; }

  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('step-' + n).classList.add('active');
  state.step = n;
  updateStepUI();

  if (n === 4) renderComposite();
  if (n === 5) finalizeExport();
}

function nextStep() {
  if (state.step === 3 && state.shots.length < SHOTS_NEEDED[state.layout]) {
    showToast(`Butuh ${SHOTS_NEEDED[state.layout]} foto. Sudah: ${state.shots.length}`);
    return;
  }
  goToStep(state.step + 1);
}

function prevStep() {
  goToStep(state.step - 1);
}

function updateStepUI() {
  const n = state.step;
  // dots
  for (let i = 1; i <= 5; i++) {
    const dot = document.getElementById('step-dot-' + i);
    dot.className = 'app-step';
    if (i === n) dot.classList.add('active');
    else if (i < n) dot.classList.add('done');
  }
  // back/next
  const back = document.getElementById('btn-back');
  const next = document.getElementById('btn-next');
  const bottomNav = document.getElementById('app-bottom-nav');

  if (n === 5) { bottomNav.style.display = 'none'; return; }
  bottomNav.style.display = 'flex';
  back.style.display = n > 1 ? 'block' : 'none';

  const labels = ['Pilih Template →', 'Kamera →', 'Edit →', 'Selesai →'];
  next.textContent = labels[n - 1] || 'Lanjut →';
}

// ══════════════════════════════
// LAYOUT SELECTION
// ══════════════════════════════
function selectLayout(type) {
  state.layout = type;
  document.querySelectorAll('.layout-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('layout-' + type).classList.add('selected');

  // Preview
  const box = document.getElementById('layout-preview-box');
  const needed = SHOTS_NEEDED[type];
  const labels = { single: '1 foto portrait penuh', quad: '4 foto 2×2 grid', strip: '6 foto strip vertikal' };
  box.innerHTML = `<div style="text-align:center"><div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--gold);">${needed}</div><div style="font-size:0.65rem;color:var(--text-muted);letter-spacing:0.1em;margin-top:0.25rem;">${labels[type]}</div></div>`;

  // Reset shots
  state.shots = [];
  renderShotSlots();
}

// ══════════════════════════════
// TEMPLATES
// ══════════════════════════════
function renderTemplates() {
  const grid = document.getElementById('template-grid');
  grid.innerHTML = filteredTemplates.map(t => `
    <div class="template-card ${state.template?.id === t.id ? 'selected' : ''}" onclick="selectTemplate('${t.id}')" id="tcard-${t.id}">
      <div class="template-bg" style="background:${t.bg};min-height:180px;border:3px solid ${t.border}22;">
        <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:0.5rem;">
          <div style="width:60%;aspect-ratio:3/4;background:rgba(0,0,0,0.2);border-radius:4px;border:1px solid ${t.border}44;"></div>
        </div>
      </div>
      <div class="template-label">${t.name}</div>
      <div class="template-check">✓</div>
    </div>
  `).join('');
}

function selectTemplate(id) {
  state.template = allTemplates.find(t => t.id === id);
  document.querySelectorAll('.template-card').forEach(c => c.classList.remove('selected'));
  const card = document.getElementById('tcard-' + id);
  if (card) card.classList.add('selected');
  showToast('Template dipilih: ' + state.template.name);
}

function setCategory(cat, btn) {
  activeCategory = cat;
  document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  filteredTemplates = cat === 'all' ? [...allTemplates] : allTemplates.filter(t => t.cat === cat);
  renderTemplates();
}

function filterTemplates(q) {
  const query = q.toLowerCase();
  filteredTemplates = allTemplates.filter(t =>
    (activeCategory === 'all' || t.cat === activeCategory) &&
    (t.name.toLowerCase().includes(query) || t.cat.includes(query))
  );
  renderTemplates();
}

// ══════════════════════════════
// CAMERA
// ══════════════════════════════
async function initCamera() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 720 } },
      audio: false
    });
    state.stream = stream;
    const video = document.getElementById('videoEl');
    video.srcObject = stream;
  } catch (e) {
    showToast('Kamera tidak tersedia. Gunakan browser modern.');
    console.warn('Camera error:', e);
  }
}

function renderShotSlots() {
  const row = document.getElementById('shots-row');
  const needed = SHOTS_NEEDED[state.layout] || 1;
  document.getElementById('shots-needed').textContent = needed;
  document.getElementById('shots-count').textContent = state.shots.length;

  row.innerHTML = Array.from({ length: needed }, (_, i) => {
    const shot = state.shots[i];
    return `<div class="shot-thumb ${shot ? 'filled' : ''}" onclick="retakeShot(${i})">
      ${shot ? `<img src="${shot}" alt="Shot ${i+1}">` : `<div class="shot-num">${i+1}</div>`}
    </div>`;
  }).join('');
}

function setTimer(s, btn) {
  state.timerSecs = s;
  document.querySelectorAll('.timer-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function capturePhoto() {
  if (!state.layout) { showToast('Pilih layout dulu'); goToStep(1); return; }
  const needed = SHOTS_NEEDED[state.layout];
  if (state.shots.length >= needed) { showToast('Semua foto sudah diambil!'); return; }

  const btn = document.getElementById('shutter-btn');
  btn.style.pointerEvents = 'none';

  if (state.timerSecs > 0) {
    startCountdown(state.timerSecs, () => {
      doCapture();
      btn.style.pointerEvents = 'auto';
    });
  } else {
    doCapture();
    btn.style.pointerEvents = 'auto';
  }
}

function startCountdown(secs, cb) {
  const el = document.getElementById('countdown');
  let n = secs;
  el.textContent = n;
  el.classList.add('visible');
  const iv = setInterval(() => {
    n--;
    if (n > 0) {
      el.textContent = n;
    } else {
      clearInterval(iv);
      el.classList.remove('visible');
      cb();
    }
  }, 1000);
}

function doCapture() {
  const video = document.getElementById('videoEl');
  const canvas = document.getElementById('snapCanvas');
  const ctx = canvas.getContext('2d');

  canvas.width = video.videoWidth || 640;
  canvas.height = video.videoHeight || 480;

  // Flash
  const flash = document.getElementById('flash-overlay');
  flash.classList.add('flash');
  setTimeout(() => flash.classList.remove('flash'), 150);

  if (state.mirrorMode) {
    ctx.scale(-1, 1);
    ctx.drawImage(video, -canvas.width, 0, canvas.width, canvas.height);
    ctx.setTransform(1, 0, 0, 1, 0, 0);
  } else {
    ctx.drawImage(video, 0, 0);
  }

  applyCameraFilter(ctx, canvas.width, canvas.height);
  const dataURL = canvas.toDataURL('image/jpeg', 0.92);
  state.shots.push(dataURL);
  renderShotSlots();

  const needed = SHOTS_NEEDED[state.layout];
  if (state.shots.length >= needed) {
    showToast('✓ Semua foto diambil! Lanjut edit →');
  }
}

function applyCameraFilter(ctx, w, h) {
  if (state.cameraFilter === 'none') return;
  const img = ctx.getImageData(0, 0, w, h);
  const d = img.data;
  for (let i = 0; i < d.length; i += 4) {
    const r = d[i], g = d[i+1], b = d[i+2];
    if (state.cameraFilter === 'warm') { d[i] = Math.min(255, r+20); d[i+2] = Math.max(0, b-20); }
    else if (state.cameraFilter === 'cool') { d[i] = Math.max(0, r-20); d[i+2] = Math.min(255, b+20); }
    else if (state.cameraFilter === 'bw') { const gr = 0.299*r+0.587*g+0.114*b; d[i]=d[i+1]=d[i+2]=gr; }
    else if (state.cameraFilter === 'vintage') { d[i]=Math.min(255,r*1.1+20); d[i+1]=Math.max(0,g*0.9); d[i+2]=Math.max(0,b*0.8); }
    else if (state.cameraFilter === 'beauty') { d[i]=Math.min(255,r*1.05+5); d[i+1]=Math.min(255,g*1.05+5); d[i+2]=Math.min(255,b*1.05+5); }
  }
  ctx.putImageData(img, 0, 0);
}

function setCameraFilter(filter, el) {
  state.cameraFilter = filter;
  document.querySelectorAll('#camera-filters .deco-item').forEach(d => d.classList.remove('active'));
  el.classList.add('active');
}

function toggleGuide() {
  state.guideGrid = !state.guideGrid;
  document.getElementById('guide-grid').classList.toggle('visible', state.guideGrid);
  document.getElementById('btn-guide').classList.toggle('active', state.guideGrid);
}

function togglePose() {
  state.poseGuide = !state.poseGuide;
  document.getElementById('pose-guide').classList.toggle('visible', state.poseGuide);
  document.getElementById('btn-pose').classList.toggle('active', state.poseGuide);
}

function toggleMirror() {
  state.mirrorMode = !state.mirrorMode;
  document.getElementById('videoEl').style.transform = state.mirrorMode ? 'scaleX(-1)' : 'none';
  document.getElementById('btn-mirror').classList.toggle('active', state.mirrorMode);
}

function retakeShot(idx) {
  if (state.shots[idx]) {
    if (confirm('Ambil ulang foto ini?')) {
      state.shots.splice(idx, 1);
      renderShotSlots();
    }
  }
}

function clearShots() {
  state.shots = [];
  renderShotSlots();
}

// ══════════════════════════════
// EDITING
// ══════════════════════════════
function setEditTab(tab, btn) {
  document.querySelectorAll('.edit-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.edit-panel-content').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('edit-' + tab).classList.add('active');
}

function adjustImage(prop, val) {
  state.adjustments[prop] = parseInt(val);
  renderComposite();
}

function applyTone(tone, btn) {
  state.tone = tone;
  document.querySelectorAll('.tone-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderComposite();
}

function addSticker(emoji) {
  state.stickers.push({ emoji, x: 0.5, y: 0.5, size: 40 });
  renderComposite();
  showToast(emoji + ' ditambahkan');
}

function addBorder(type) {
  state.border = type;
  renderComposite();
}

function addFrameDeco(type) {
  state.frameDeco = type;
  renderComposite();
}

function addEdgeText(type) {
  state.edgeText = type;
  renderComposite();
}

function toggleWatermark(btn) {
  state.watermark = !state.watermark;
  btn.classList.toggle('on', state.watermark);
  renderComposite();
}

function toggleDate(btn) {
  state.showDate = !state.showDate;
  btn.classList.toggle('on', state.showDate);
  renderComposite();
}

function setFont(font, btn) {
  state.font = font;
  document.querySelectorAll('.font-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function setTextColor(color, el) {
  state.textColor = color;
  document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
}

function setTextSize(s) { state.textSize = parseInt(s); }

function addTextOverlay() {
  const txt = document.getElementById('custom-text').value.trim();
  if (!txt) { showToast('Tulis teks dulu'); return; }
  state.texts.push({
    content: txt,
    font: state.font,
    color: state.textColor,
    size: state.textSize,
    x: 0.5, y: 0.85
  });
  renderComposite();
  showToast('Teks ditambahkan!');
}

// ══════════════════════════════
// CANVAS COMPOSITE
// ══════════════════════════════
function renderComposite() {
  const canvas = document.getElementById('compositeCanvas');
  drawComposite(canvas, 400, getCompositeHeight(400));
}

function getCompositeHeight(w) {
  if (state.layout === 'strip') return w * 2.5;
  if (state.layout === 'quad') return w * 1.2;
  return w * 1.35;
}

function getCanvasFontName(font) {
  const map = {
    'cormorant': 'Cormorant Garamond',
    'dancing': 'Dancing Script',
    'playfair': 'Playfair Display',
    'grotesk': 'Space Grotesk'
  };
  return map[font] || 'Cormorant Garamond';
}

function drawComposite(canvas, w, h) {
  canvas.width = w;
  canvas.height = h;
  const ctx = canvas.getContext('2d');
  const t = state.template;

  // BG
  if (t) {
    if (t.bg.startsWith('linear-gradient') || t.bg.startsWith('radial-gradient')) {
      const grad = parseGradient(ctx, t.bg, w, h);
      if (grad) { ctx.fillStyle = grad; ctx.fillRect(0, 0, w, h); }
      else { ctx.fillStyle = '#1a1a1a'; ctx.fillRect(0, 0, w, h); }
    } else {
      ctx.fillStyle = t.bg;
      ctx.fillRect(0, 0, w, h);
    }
  } else {
    ctx.fillStyle = '#1a1a1a';
    ctx.fillRect(0, 0, w, h);
  }

  // Draw photos
  const pad = 20;
  drawPhotos(ctx, w, h, pad);

  // Apply tone overlay
  applyToneOverlay(ctx, w, h);

  // Adjustments
  applyAdjustments(ctx, w, h);

  // Stickers
  state.stickers.forEach(s => {
    ctx.font = `${s.size}px serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(s.emoji, s.x * w, s.y * h);
  });

  // Frame deco
  drawFrameDeco(ctx, w, h);

  // Border
  drawBorder(ctx, w, h);

  // Texts
  state.texts.forEach(txt => {
    const fontName = getCanvasFontName(txt.font);
    ctx.font = `${txt.size}px "${fontName}"`;
    ctx.fillStyle = txt.color;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.shadowColor = 'rgba(0,0,0,0.5)';
    ctx.shadowBlur = 6;
    ctx.fillText(txt.content, txt.x * w, txt.y * h);
    ctx.shadowBlur = 0;
  });

  // Watermark + Date
  if (state.watermark || state.showDate) {
    ctx.font = '11px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillStyle = t ? t.accent + 'CC' : 'rgba(201,169,110,0.8)';
    let wText = '';
    if (state.watermark) wText += document.getElementById('watermark-text')?.value || 'LUMIÈRE Studio';
    if (state.showDate && state.watermark) wText += '  •  ';
    if (state.showDate) wText += new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
    ctx.fillText(wText, w / 2, h - 6);
  }
}

function parseGradient(ctx, gradStr, w, h) {
  try {
    const isLinear = gradStr.startsWith('linear-gradient');
    let grad;
    if (isLinear) {
      const angleMatch = gradStr.match(/(\d+)deg/);
      const angle = angleMatch ? parseInt(angleMatch[1]) * Math.PI / 180 : Math.PI / 4;
      const x1 = w/2 - Math.cos(angle) * w;
      const y1 = h/2 - Math.sin(angle) * h;
      const x2 = w/2 + Math.cos(angle) * w;
      const y2 = h/2 + Math.sin(angle) * h;
      grad = ctx.createLinearGradient(x1, y1, x2, y2);
    } else {
      grad = ctx.createRadialGradient(w/2, h/2, 0, w/2, h/2, Math.max(w,h));
    }
    const colors = gradStr.match(/#[0-9a-fA-F]{3,8}/g) || [];
    if (colors.length < 2) return null;
    colors.forEach((c, i) => grad.addColorStop(i / (colors.length - 1), c));
    return grad;
  } catch(e) { return null; }
}

function drawPhotos(ctx, w, h, pad) {
  const shots = state.shots;
  if (!shots.length) return;
  const layout = state.layout;
  const tasks = [];

  if (layout === 'single') {
    tasks.push({ src: shots[0], x: pad, y: pad, w: w-pad*2, h: h-pad*2 });
  } else if (layout === 'quad') {
    const cw = (w - pad*3) / 2;
    const ch = (h - pad*3) / 2;
    [[0,0],[1,0],[0,1],[1,1]].forEach(([col,row], i) => {
      if (shots[i]) tasks.push({ src: shots[i], x: pad + col*(cw+pad), y: pad + row*(ch+pad), w: cw, h: ch });
    });
  } else if (layout === 'strip') {
    const ph = (h - pad*7) / 6;
    shots.forEach((s, i) => {
      tasks.push({ src: s, x: pad, y: pad + i*(ph+pad), w: w-pad*2, h: ph });
    });
  }

  tasks.forEach(task => {
    const img = new Image();
    img.onload = () => {
      ctx.save();
      ctx.beginPath();
      ctx.roundRect(task.x, task.y, task.w, task.h, 6);
      ctx.clip();
      // cover fit
      const ratio = Math.max(task.w / img.width, task.h / img.height);
      const sw = img.width * ratio, sh = img.height * ratio;
      const sx = task.x + (task.w - sw) / 2, sy = task.y + (task.h - sh) / 2;
      ctx.drawImage(img, sx, sy, sw, sh);
      ctx.restore();
    };
    img.src = task.src;
  });
}

function applyToneOverlay(ctx, w, h) {
  const tones = {
    warm: ['rgba(255,160,60,0.18)', null],
    cool: ['rgba(60,120,255,0.18)', null],
    bw: ['rgba(0,0,0,0)', 'grayscale(1)'],
    vintage: ['rgba(180,130,60,0.22)', null],
    cinematic: ['rgba(0,20,40,0.35)', null],
    rose: ['rgba(212,120,140,0.2)', null],
    mint: ['rgba(80,200,140,0.18)', null],
  };
  if (state.tone !== 'none' && tones[state.tone]) {
    const [overlay] = tones[state.tone];
    if (overlay) {
      ctx.fillStyle = overlay;
      ctx.fillRect(0, 0, w, h);
    }
  }
}

function applyAdjustments(ctx, w, h) {
  const adj = state.adjustments;
  if (adj.vignette > 0) {
    const strength = adj.vignette / 100;
    const grad = ctx.createRadialGradient(w/2, h/2, Math.min(w,h)*0.3, w/2, h/2, Math.max(w,h)*0.8);
    grad.addColorStop(0, 'rgba(0,0,0,0)');
    grad.addColorStop(1, `rgba(0,0,0,${strength * 0.7})`);
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, w, h);
  }
}

function drawFrameDeco(ctx, w, h) {
  if (state.frameDeco === 'none') return;
  const decorations = {
    flowers: ['🌸','🌺','🌹','🌼','🌻'],
    stars: ['✨','⭐','💫','🌟','✦'],
    hearts: ['💖','💕','❤️','💗','💓'],
    ribbons: ['🎀','🎁','🎊','🎉','✦'],
    doodle: ['✦','◆','●','▲','✱']
  };
  const emojis = decorations[state.frameDeco] || [];
  ctx.font = '20px serif';
  ctx.textAlign = 'center';
  // corners
  const corners = [[15, 15], [w-15, 15], [15, h-15], [w-15, h-15]];
  corners.forEach(([x, y], i) => {
    ctx.fillText(emojis[i % emojis.length] || '✦', x, y);
  });
}

function drawBorder(ctx, w, h) {
  const borders = {
    gold: { color: '#C9A96E', width: 4, shadow: 'rgba(201,169,110,0.5)' },
    silver: { color: '#C0C0C0', width: 3, shadow: 'rgba(192,192,192,0.5)' },
    neon: { color: '#00FFFF', width: 3, shadow: 'rgba(0,255,255,0.8)' },
    rose: { color: '#D4788A', width: 3, shadow: 'rgba(212,120,138,0.5)' }
  };
  const b = borders[state.border];
  if (!b) return;
  ctx.strokeStyle = b.color;
  ctx.lineWidth = b.width;
  ctx.shadowColor = b.shadow;
  ctx.shadowBlur = 10;
  ctx.strokeRect(b.width/2, b.width/2, w-b.width, h-b.width);
  ctx.shadowBlur = 0;
}

// ══════════════════════════════
// EXPORT
// ══════════════════════════════
function finalizeExport() {
  const canvas = document.getElementById('exportCanvas');
  const W = 800;
  const H = getCompositeHeight(W);
  drawComposite(canvas, W, H);
}

function downloadHD() {
  finalizeExport();
  setTimeout(() => {
    const canvas = document.getElementById('exportCanvas');
    const link = document.createElement('a');
    link.download = `lumiere-${Date.now()}.jpg`;
    link.href = canvas.toDataURL('image/jpeg', 0.95);
    link.click();
    showToast('✓ Foto berhasil didownload!');
  }, 300);
}

function shareInstagram() {
  finalizeExport();
  setTimeout(() => {
    const canvas = document.getElementById('exportCanvas');
    canvas.toBlob(blob => {
      if (navigator.share) {
        navigator.share({ files: [new File([blob], 'lumiere.jpg', { type: 'image/jpeg' })] })
          .catch(() => showToast('Share dibatalkan'));
      } else {
        downloadHD();
        showToast('Download foto, lalu upload ke Instagram');
      }
    }, 'image/jpeg', 0.95);
  }, 300);
}

function shareWhatsApp() {
  downloadHD();
  setTimeout(() => showToast('Foto didownload. Buka WhatsApp untuk berbagi!'), 500);
}

function generateQR() {
  showToast('QR Code: Gunakan link download langsung');
  downloadHD();
}

function printMode() {
  finalizeExport();
  setTimeout(() => {
    const canvas = document.getElementById('exportCanvas');
    const win = window.open('', '_blank');
    win.document.write(`<html><head><title>Print - Lumière</title><style>body{margin:0;display:flex;align-items:center;justify-content:center;min-height:100vh;background:#fff;}img{max-width:100%;max-height:100vh;}</style></head><body><img src="${canvas.toDataURL()}"></body></html>`);
    win.document.close();
    win.onload = () => { win.print(); };
  }, 300);
}

// ══════════════════════════════
// TOAST
// ══════════════════════════════
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer = setTimeout(() => t.classList.remove('show'), 2500);
}

// ══════════════════════════════
// INIT SHOT SLOTS WHEN STEP 3 IS SHOWN
// ══════════════════════════════
const origGoToStep = goToStep;
window.addEventListener('DOMContentLoaded', () => {
  document.getElementById('step-dot-3').addEventListener('click', () => {
    if (state.layout) renderShotSlots();
  });
});
</script>
</body>
</html>
